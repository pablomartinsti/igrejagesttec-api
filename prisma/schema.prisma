generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Church {
  id              String   @id @default(uuid())
  name            String
  cnpj            String?  @unique
  street          String?
  neighborhood    String?
  city            String?
  state           String?
  zipCode         String?
  phone           String?
  email           String?
  responsibleName String?
  createdAt       DateTime @default(now())

  users               User[]
  categories          Category[]
  transactions        Transaction[]
  cultos              Culto[]
  spiritualCategories SpiritualCategory[]
  cultoCategories     CultoCategory[]

  @@map("churches")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(TREASURER)
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id])
  createdAt DateTime @default(now())

  @@map("users")
}

enum UserRole {
  ADMIN
  TREASURER
  PASTOR
}

model CultoCategory {
  id       String  @id @default(uuid())
  title    String
  churchId String
  church   Church  @relation(fields: [churchId], references: [id])
  cultos   Culto[]

  @@unique([title, churchId])
  @@map("culto_categories")
}

model Culto {
  id         String        @id @default(uuid())
  date       DateTime
  categoryId String
  category   CultoCategory @relation(fields: [categoryId], references: [id])
  preacher   String?
  churchId   String
  church     Church        @relation(fields: [churchId], references: [id])
  createdAt  DateTime      @default(now())

  dizimistas       Dizimista[]
  spiritualRecords SpiritualRecord[]
  transactions     Transaction[]

  @@map("cultos")
}

model Dizimista {
  id               String  @id @default(uuid())
  name             String?
  amount           Int
  contributionType String?
  cultoId          String
  culto            Culto   @relation(fields: [cultoId], references: [id])

  @@map("dizimistas")
}

model SpiritualCategory {
  id       String @id @default(uuid())
  title    String
  churchId String
  church   Church @relation(fields: [churchId], references: [id])

  records SpiritualRecord[]

  @@unique([title, churchId])
  @@map("spiritual_categories")
}

model SpiritualRecord {
  id         String            @id @default(uuid())
  value      Int
  cultoId    String
  culto      Culto             @relation(fields: [cultoId], references: [id])
  categoryId String
  category   SpiritualCategory @relation(fields: [categoryId], references: [id])

  @@map("spiritual_records")
}

model Category {
  id           String        @id @default(uuid())
  title        String
  color        String
  churchId     String
  church       Church        @relation(fields: [churchId], references: [id])
  transactions Transaction[]

  @@unique([title, churchId])
  @@map("categories")
}

model Transaction {
  id         String          @id @default(uuid())
  title      String
  amount     Int
  type       TransactionType
  date       DateTime
  categoryId String
  category   Category        @relation(fields: [categoryId], references: [id])
  churchId   String
  church     Church          @relation(fields: [churchId], references: [id])
  cultoId    String?
  culto      Culto?          @relation(fields: [cultoId], references: [id])

  @@map("transactions")
}

enum TransactionType {
  income
  expense
}